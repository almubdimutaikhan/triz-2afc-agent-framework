# Copy this file to `.env` and fill in ONE key. `.env` is git-ignored.
#
# All model calls go through a single OpenAI-compatible gateway
# (`{gateway_base_url}/chat/completions`, Bearer auth), so one key reaches
# every model family. Set `gateway_base_url` in config.yaml to match the key
# you provide below.
#
# Keys are read in this order (first non-empty wins), from the environment
# first, then this file:
#   AI_OPENROUTER_API_KEY  ->  OPENROUTER_API_KEY
#   AI_GATEWAY_API_KEY     ->  VERCEL_AI_GATEWAY_API_KEY

# --- Option A: OpenRouter (https://openrouter.ai)  gateway_base_url: https://openrouter.ai/api/v1
AI_OPENROUTER_API_KEY=

# --- Option B: Vercel AI Gateway  gateway_base_url: https://ai-gateway.vercel.sh/v1
# AI_GATEWAY_API_KEY=
