# ---- python ----
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/
.venv/
.python-version

# ---- OS / editor cruft ----
.DS_Store
*.swp

# ---- run outputs & caches (reproducible from the pipeline) ----
# The on-disk generation/judgement cache. Large and regenerable; keep it local.
data/
# Flat CSV exports of every generation and judgement.
*.csv
# ...except the curated evidence files in the RA progress report.
!report/*.csv
# Rendered/report build artifacts.
*.html
*.pdf
# Built 2AFC pair files.
pairs*.json
!results/**/pairs*.json

# ---- archived runs & working scratch (not part of the framework) ----
runs/
search/
casebase.backup*.json

# ---- copyrighted source documents (Oxford Creativity etc.) ----
# Prof-supplied reference PDFs/XLSX. The extracted attachment text used in
# prompts is versioned at prompts/p40/attachments/; the sources stay local.
docs/

